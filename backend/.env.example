# Local dev defaults to SQLite (no install needed).
# For PostgreSQL (production target), use:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/expense_intelligence
DATABASE_URL=sqlite:///./expense_intelligence.db

# Where uploaded statement files are stored
UPLOAD_DIR=./uploads

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Weekly digest / email (all optional) ---
# Delivery is chosen automatically: Brevo API > SMTP > digest_outbox/ file.
#
# Preferred: Brevo HTTP API (works everywhere, including hosts like Render that
# block outbound SMTP). Key starts with "xkeysib-"; DIGEST_FROM must be a sender
# you've verified in Brevo.
BREVO_API_KEY=
DIGEST_FROM=digest@expense-intelligence.local
DIGEST_FROM_NAME=Expense Intelligence
DIGEST_TO=
# Fallback: SMTP (for local dev). Leave blank to write digests to
# backend/digest_outbox/ instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Run the digest every N minutes instead of weekly (handy for a live demo). 0 = weekly.
DIGEST_INTERVAL_MINUTES=0

# --- Auth ---
# REQUIRED in production: a strong random secret (`openssl rand -hex 32`).
JWT_SECRET_KEY=
# Set COOKIE_SECURE=true when serving over HTTPS. Use COOKIE_SAMESITE=none
# (with secure) only if the API and frontend are on different sites.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
