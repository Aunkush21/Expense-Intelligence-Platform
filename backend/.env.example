# Local dev defaults to SQLite (no install needed).
# For PostgreSQL (production target), use:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/expense_intelligence
DATABASE_URL=sqlite:///./expense_intelligence.db

# Where uploaded statement files are stored
UPLOAD_DIR=./uploads

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
